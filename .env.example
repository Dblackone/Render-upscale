# ============================================================
# Render-upscale — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See docs/mcp/AUTHENTICATION.md for setup instructions.

# ------------------------------------------------------------
# CORE API KEYS
# ------------------------------------------------------------

# Anthropic API key — used for Claude vision image analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key — used for DALL-E 3 image generation
OPENAI_API_KEY=your_openai_api_key_here

# Web server port (optional, default 8000)
PORT=8000

# ------------------------------------------------------------
# NANO BANANA 2 MCP — Pixa remote server
# Obtain your API key from https://pixa.com
# Used to authenticate requests to https://mcp.pixa.com/mcp
# ------------------------------------------------------------
PIXA_API_KEY=your_pixa_api_key_here
