# ============================================================
# Render-upscale — Nano Banana MCP Server Environment Config
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# See docs/mcp/AUTHENTICATION.md for setup instructions.

# ------------------------------------------------------------
# REQUIRED: Google Gemini API Key
# Obtain from: https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# IMAGE OUTPUT DIRECTORY
# Where generated and enhanced renders are saved.
# Default matches project structure: ./images/enhanced-renders
# Use absolute path or path relative to project root.
# ------------------------------------------------------------
IMAGE_OUTPUT_DIR=./images/enhanced-renders

# ------------------------------------------------------------
# MODEL SELECTION
# Options:
#   auto  — Smart routing (recommended). Upgrades to Pro for
#           quality keywords: "4K", "professional", "high-res",
#           "ultra", "photorealistic", "architectural"
#   flash — Always use Gemini 2.5 Flash (fast, cost-efficient)
#   nb2   — Always use Nano Banana 2 / Gemini 3.1 Flash Image
#   pro   — Always use Pro model (highest quality, slower)
# ------------------------------------------------------------
NANOBANANA_MODEL=auto

# ------------------------------------------------------------
# LOGGING
# Options: DEBUG, INFO, WARNING, ERROR
# Use DEBUG during setup to trace MCP tool calls.
# ------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------
# AUTHENTICATION METHOD
# Options:
#   api_key  — Use GEMINI_API_KEY (standard, recommended)
#   vertex   — Use Google Cloud Vertex AI (enterprise)
# ------------------------------------------------------------
NANOBANANA_AUTH_METHOD=api_key

# ------------------------------------------------------------
# VERTEX AI (only required if NANOBANANA_AUTH_METHOD=vertex)
# GCP_PROJECT_ID: Your Google Cloud project ID
# GCP_REGION: Vertex AI region (e.g. us-central1, europe-west1)
# Authentication: run `gcloud auth application-default login`
# ------------------------------------------------------------
GCP_PROJECT_ID=
GCP_REGION=us-central1
